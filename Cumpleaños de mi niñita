<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Feliz Cumpleaños Katia ❤️</title>

<style>

@import url('https://fonts.googleapis.com/css2?family=Great+Vibes&family=Poppins:wght@400;600&display=swap');

*{
margin:0;
padding:0;
box-sizing:border-box;
}

body{
height:100vh;
overflow:hidden;
background:linear-gradient(135deg,#160022,#8e24aa,#ff80ab);
color:white;
display:flex;
justify-content:center;
align-items:center;
font-family:Poppins;
}

.estrellas{
position:absolute;
width:100%;
height:100%;
background-image:radial-gradient(white 1px,transparent 1px);
background-size:35px 35px;
animation:estrellas 10s linear infinite;
}

@keyframes estrellas{
to{
background-position:200px 200px;
}
}

.contenido{
position:relative;
z-index:2;
text-align:center;
padding:15px;
transform:translateY(-70px);
}

h1{
font-family:'Great Vibes',cursive;
font-size:55px;
text-shadow:0 0 25px pink;
margin-bottom:25px;
animation:brillo 2s infinite alternate;
}

@keyframes brillo{
from{filter:brightness(1);}
to{filter:brightness(1.5);}
}

.regalo{
font-size:110px;
cursor:pointer;
animation:saltar 1.5s infinite;
}

@keyframes saltar{
50%{
transform:translateY(-15px);
}
}

button{
padding:12px 30px;
border:none;
border-radius:30px;
font-size:20px;
background:#ff4fa3;
color:white;
box-shadow:0 0 20px pink;
}

#cumple{
display:none;
}


/* PASTEL RANCHO */

.pastel{
width:200px;
height:110px;
background:#9b5a2e;
border:5px solid #5c3218;
border-radius:20px;
margin:50px auto 25px;
position:relative;
cursor:pointer;
box-shadow:0 0 30px #d89b5b;
}

.pastel:before{
content:"";
position:absolute;
top:-30px;
left:0;
width:200px;
height:35px;
background:#fff0d5;
border-radius:20px;
}

.sombrero{
position:absolute;
top:-75px;
left:70px;
font-size:45px;
}

.vela{
width:12px;
height:50px;
background:white;
position:absolute;
top:-75px;
left:90px;
}

.fuego{
width:20px;
height:25px;
background:orange;
border-radius:50%;
position:absolute;
top:-25px;
left:-4px;
box-shadow:0 0 20px yellow;
animation:fuego .5s infinite alternate;
}

@keyframes fuego{
to{
transform:scale(1.3);
}
}

.detalles{
font-size:25px;
margin-top:45px;
}

.numero{
font-size:45px;
font-weight:bold;
}

.carta{
background:rgba(255,255,255,.15);
border-radius:20px;
padding:15px;
max-width:350px;
margin:auto;
font-size:15px;
}.globo{
position:absolute;
bottom:-100px;
width:60px;
height:80px;
border-radius:50%;
animation:subir 9s infinite linear;
}

@keyframes subir{
to{
transform:translateY(-120vh);
}
}

.g1{left:10%;background:#ff3366;}
.g2{left:50%;background:#ffd633;animation-delay:2s;}
.g3{left:80%;background:#3399ff;animation-delay:4s;}

</style>
</head>

<body>

<div class="estrellas"></div>

<div class="globo g1"></div>
<div class="globo g2"></div>
<div class="globo g3"></div>


<div class="contenido" id="inicio">

<h1>
Tengo una sorpresa para ti ❤️
</h1>

<div class="regalo">
🎁
</div>

<button onclick="abrir()">
Abrir mi regalo 💖
</button>

</div>



<div class="contenido" id="cumple">

<h1>
¡Feliz Cumpleaños, Amor! ❤️
</h1>


<div class="pastel" onclick="apagar()">

<div class="sombrero">
🤠
</div>


<div class="vela">
<div class="fuego" id="llama"></div>
</div>


<div class="detalles">
🌸 🐴 🤎
</div>

</div>


<div class="numero">
17 AÑOS 🎂
</div>


<h2 id="mensaje">
Pide un deseo ✨<br>
Toca la vela para apagarla 🕯️
</h2>


<div class="carta">

<h2>
Katia ❤️
</h2>

<p>
Feliz cumpleaños, mi niña hermosa ❤️

Espero que tengas un día lleno de felicidad y momentos bonitos.

Estoy muy orgulloso de ti y de todo lo que haces.
Nunca dejes de luchar por tus sueños.

Te amo muchísimo ✨
</p>

</div>


</div>



<script>

function abrir(){

document.getElementById("inicio").style.display="none";

document.getElementById("cumple").style.display="block";

}


function apagar(){

document.getElementById("llama").style.display="none";


document.getElementById("mensaje").innerHTML=
"✨ Que todos tus deseos se cumplan, Katia ❤️✨";


for(let i=0;i<40;i++){

let f=document.createElement("div");

f.innerHTML="🎆";

f.style.position="absolute";
f.style.left=Math.random()*100+"%";
f.style.top=Math.random()*80+"%";
f.style.fontSize="40px";

document.body.appendChild(f);


setTimeout(()=>{
f.remove();
},2000);

}

}

</script>

</body>
</html>
